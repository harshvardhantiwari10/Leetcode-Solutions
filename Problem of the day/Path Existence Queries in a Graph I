class Solution(object):
    def pathExistenceQueries(self, n, nums, maxDiff, queries):
        """
        :type n: int
        :type nums: List[int]
        :type maxDiff: int
        :type queries: List[List[int]]
        :rtype: List[bool]
        """
        parent = list(range(n))
        
        def find(i):
            if parent[i] == i:
                return i
            parent[i] = find(parent[i])
            return parent[i]
        
        def union(i, j):
            root_i = find(i)
            root_j = find(j)
            if root_i != root_j:
                parent[root_i] = root_j
                
        # Only check adjacent elements due to sorted property
        for i in range(n - 1):
            if nums[i+1] - nums[i] <= maxDiff:
                union(i, i + 1)
                
        # Process queries
        results = []
        for u, v in queries:
            results.append(find(u) == find(v))
            
        return results
